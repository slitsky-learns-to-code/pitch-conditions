# Copy this file to `.env.local` and fill in your real values.
# `.env.local` is gitignored — never commit your keys.
#
# Find these in Supabase: Dashboard → Project Settings → API
#   - VITE_SUPABASE_URL      = "Project URL"
#   - VITE_SUPABASE_ANON_KEY = "anon / public" key  (safe for the browser)
#
# ⚠️  Never put the "service_role" key here or anywhere in the frontend —
#     it bypasses Row-Level Security.
#
# The VITE_ prefix is required for Vite to expose the variable to the app.

VITE_SUPABASE_URL=your-project-url-here
VITE_SUPABASE_ANON_KEY=your-anon-key-here
